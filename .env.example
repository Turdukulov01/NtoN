POSTGRES_PASSWORD=change_this_postgres_password
GRAFANA_PASSWORD=change_this_grafana_password

# Required for TRON wallet sync and graph tracing.
# Put your Tronscan API key here before starting docker compose.
TRONSCAN_API_KEY=

# Default Tronscan API endpoint. Change only if Tronscan changes its host.
TRONSCAN_BASE_URL=https://apilist.tronscanapi.com/api

# Optional external KYT provider. Keep the real key only in .env or deployment secrets.
RANEX_API_KEY=
RANEX_BASE_URL=https://kyt-api.ranex.asia

# Shard Risk API uses HMAC auth and needs both values.
SHARD_PUBLIC_APP_ID=
SHARD_API_SECRET=
SHARD_BASE_URL=https://shard.ru
KYT_PROVIDER_CACHE_TTL_SECONDS=86400
